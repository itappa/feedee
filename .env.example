# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,app.local,app.localhost,web,app-web
DATABASE_URL=postgresql://feedee:feedee@postgres:5432/feedee

# PostgreSQL (standalone production or shared LAN infra)
POSTGRES_DB=feedee
POSTGRES_USER=feedee
POSTGRES_PASSWORD=feedee
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Nginx (production only)
NGINX_PORT=80

# CSRF trusted origins (comma-separated)
CSRF_TRUSTED_ORIGINS=http://app.local,http://app.localhost

# Shared LAN override vars used by compose.local-proxy.yaml
FEEDEE_ALLOWED_HOSTS=localhost,127.0.0.1,app.local,app.localhost,web,app-web
FEEDEE_CSRF_TRUSTED_ORIGINS=http://app.local,http://app.localhost
FEEDEE_VITE_HMR_HOST=app.localhost
FEEDEE_VITE_CLIENT_PORT=5174
FEEDEE_VITE_DEV_URL=http://app.localhost:5174

# RSS Worker
# DJANGO_BASE_URL is set in compose files; override here if needed
# HTTP_TIMEOUT_SECONDS=15
# MAX_CONCURRENCY=8
# INGEST_MAX_RETRY=3
# INGEST_INITIAL_BACKOFF_SECONDS=1
