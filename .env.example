# Copy to `.env` and replace with local or production values.
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DATABASE_URL=postgresql://feedee:feedee@postgres:5432/feedee

POSTGRES_DB=feedee
POSTGRES_USER=feedee
POSTGRES_PASSWORD=feedee
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,feedee.local,feedee.localhost,web,feedee-web
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://feedee.local,http://feedee.localhost

WORKER_API_TOKEN=change-me-to-a-random-token
